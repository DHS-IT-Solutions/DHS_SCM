	partition 'Date Table' = calculated
		mode: import
		source =
				
				ADDCOLUMNS(
				    CALENDAR(
				        DATEVALUE(MIN('analytics purchasing_document'[GR_date])),
				        DATEVALUE(MAX('analytics purchasing_document'[GR_date]))
				    ),
				    "Year", YEAR([Date]),
				    "MonthNo", MONTH([Date]),
				    "Month", FORMAT([Date], "MMM"),
				    "YearMonth", FORMAT([Date], "YYYY-MM"),
				    "Month Year", FORMAT([Date], "MMM YYYY")
				)

	annotation PBI_Id = f68c42d0d9ed492da3203a9839ddf8f7

