	column 'Material Category' =
			
			VAR t = LOWER('analytics current_stock'[Material_Type_Text] )
			RETURN
			SWITCH(
			    TRUE(),
			
			    CONTAINSSTRING(t, "raw"), "Raw Material",
			    CONTAINSSTRING(t, "roh"), "Raw Material",
			
			    CONTAINSSTRING(t, "semi"), "Semi Finished",
			    CONTAINSSTRING(t, "halb"), "Semi Finished",
			
			    CONTAINSSTRING(t, "finished"), "Finished Goods",
			    CONTAINSSTRING(t, "fert"), "Finished Goods",
			
			    CONTAINSSTRING(t, "trading"), "Trading Goods",
			    CONTAINSSTRING(t, "hawa"), "Trading Goods",
			
			    CONTAINSSTRING(t, "pack"), "Packaging",
			    CONTAINSSTRING(t, "returnable"), "Packaging",
			
			    CONTAINSSTRING(t, "spare"), "Spare Parts",
			
			    CONTAINSSTRING(t, "service"), "Services / Non-Stock",
			    CONTAINSSTRING(t, "software"), "Services / Non-Stock",
			
			    "Other"
			)
		lineageTag: 03437598-17ae-43b6-a0e5-0df6349b557a
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column 'Inventory Age Bucket' =
			
			VAR LastCons = 'analytics current_stock'[Last_consumption]
			RETURN
			SWITCH(
			    TRUE(),
			    ISBLANK(LastCons), "No Movement",
			    LastCons > DATE(2025, 12, 29), "Future Date Error",
			    LastCons >= DATE(2025, 11, 29) && LastCons <= DATE(2025, 12, 29), "0-30 Days",
			    LastCons >= DATE(2025, 10, 30) && LastCons <= DATE(2025, 11, 28), "31-60 Days",
			    LastCons >= DATE(2025, 9, 30) && LastCons <= DATE(2025, 10, 29), "61-90 Days",
			    LastCons >= DATE(2025, 7, 2) && LastCons <= DATE(2025, 9, 29), "Slow Moving",
			    LastCons < DATE(2025, 7, 2), "Dead Stock",
			    "Other"
			)
		lineageTag: 28b98bcf-fd3f-40cc-bc09-dce827761ed0
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column 'Stock Status' =
			
			SWITCH(
			    TRUE(),
			    'analytics current_stock'[Total_Stock] <= 0, "Out of Stock",
			    'analytics current_stock'[Total_Stock] <= 100, "Low",
			    'analytics current_stock'[Total_Stock] <= 200, "Mid",
			    'analytics current_stock'[Total_Stock] > 300, "High"
			)
		lineageTag: 5a2d3438-a30b-46f8-898d-fa11d3b2456b
		summarizeBy: none
		sortByColumn: 'Stock Status Sort'

		changedProperty = SortByColumn

		annotation SummarizationSetBy = Automatic

	column All = "All"
		lineageTag: 6f2066cf-363c-4bcd-b440-9501372b9903
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

