table 'analytics current_stock'
	lineageTag: 74fd5048-fda8-4c23-bd62-ba99c89bf9fc

	measure 'Out of Stock Materials' =
			
			COALESCE(
			    CALCULATE(
			        COUNTROWS('analytics current_stock'),
			        'analytics current_stock'[Total_Stock] = 0
			    ),
			    0
			)
		formatString: 0
		lineageTag: 3b8fa13e-5b04-4945-992a-2c8fc8c64b07

	measure 'Total Quantity' =
			
			COALESCE(
			    SUM('analytics current_stock'[Total_Stock]),
			    0
			)
		formatString: 0
		lineageTag: 99c92d99-7455-471d-afa5-4212b906093d

	measure 'Total Inventory Value' =
			
			COALESCE(
			    SUM( 'analytics current_stock'[Total_Value]),
			    0
			)
		lineageTag: a2166204-095a-450d-8a1d-1232c7769aad

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Slow Moving Quantity' =
			
			COALESCE(
			    CALCULATE(
			        SUM('analytics current_stock'[Total_Stock]),
			        FILTER(
			            'analytics current_stock',
			            NOT ISBLANK('analytics current_stock'[Last_consumption]) &&
			            'analytics current_stock'[Last_consumption] >= DATE(2025, 7, 2) &&
			            'analytics current_stock'[Last_consumption] <= DATE(2025, 9, 29)
			        )
			    ),
			    0
			)
		formatString: 0
		lineageTag: 024a2498-e95d-49f6-8e07-58d7373f0e9f

	measure 'Dead Stock Value' =
			
			COALESCE(
			    CALCULATE(
			        SUM('analytics current_stock'[Total_Value]),
			        FILTER(
			            'analytics current_stock',
			            NOT ISBLANK('analytics current_stock'[Last_consumption]) &&
			            'analytics current_stock'[Last_consumption] < DATE(2025, 7, 2)
			        )
			    ),
			    0
			)
		lineageTag: 6a46fdfc-6899-470d-bc52-87647164e033

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Material Count' = DISTINCTCOUNT( 'analytics current_stock'[Material] )
		formatString: 0
		lineageTag: ea54ba27-6c0e-462a-8fc0-cf46fa4b1b0f

