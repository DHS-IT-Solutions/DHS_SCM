table DimCustomer
	lineageTag: 0223b7d7-9ce9-4492-9513-865b67f095e4

	measure 'Count Sales' = COUNTROWS(FactSales) * 1.0932
		formatString: 0
		lineageTag: ec5a133e-e7f7-4316-a41d-412176f3ef37

	measure 'Count Invoices' = COUNTROWS(FactSales) * 0.8907
		formatString: 0
		lineageTag: 15391f23-9164-4a43-8996-3bbe0d3552aa

		annotation PBI_FormatHint = {"isDecimal":true}

	measure 'max units by item' = MAXX( ALLSELECTED( DimProduct[ProductName]) , [Units]) * 1.5
		lineageTag: 5b311886-39a6-4439-8f79-0a8f14443ed8

		annotation PBI_FormatHint = {"isGeneralNumber":true}

